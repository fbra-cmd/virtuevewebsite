# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# For local development:
DATABASE_URL=postgresql://username:password@localhost:5432/your_database

# For production (example with common providers):
# Render: postgresql://user:pass@host/dbname
# Railway: postgresql://postgres:pass@host:port/railway
# Supabase: postgresql://postgres:pass@host:5432/postgres

# Client URL for CORS (set this in production)
CLIENT_URL=https://your-domain.com
